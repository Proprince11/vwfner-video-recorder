<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".MainActivity">

    <!-- Camera Preview - fills the entire screen -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top Bar: Timer + Flash indicator -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="16dp"
        android:paddingTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Recording indicator dot -->
        <View
            android:id="@+id/recordingDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/recording_dot"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <!-- Recording timer -->
        <TextView
            android:id="@+id/timerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:background="@drawable/timer_background"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:visibility="gone"
            tools:visibility="visible" />

    </LinearLayout>

    <!-- Bottom Controls Bar -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="32dp"
        android:paddingBottom="48dp"
        android:paddingTop="24dp"
        android:background="@drawable/bottom_gradient"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Gallery / Last recording thumbnail placeholder -->
        <FrameLayout
            android:id="@+id/galleryButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/gallery_button_bg"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_gallery"
                android:contentDescription="Gallery"
                app:tint="@color/white" />

        </FrameLayout>

        <!-- RECORD button - the main star -->
        <FrameLayout
            android:id="@+id/recordButton"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_weight="0"
            android:layout_gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Record Video">

            <!-- Outer ring -->
            <View
                android:id="@+id/recordButtonOuter"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:background="@drawable/record_button_outer" />

            <!-- Inner circle/square (animates on recording) -->
            <View
                android:id="@+id/recordButtonInner"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:background="@drawable/record_button_inner" />

        </FrameLayout>

        <!-- Switch camera button -->
        <FrameLayout
            android:id="@+id/switchCameraButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/control_button_bg"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_switch_camera"
                android:contentDescription="Switch Camera"
                app:tint="@color/white" />

        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
